{
  "name": "dear-claude",
  "version": "1.0.0",
  "description": "MCP server that triggers local Claude Code instances from external platforms (Linear, Gmail, GitHub) when 'dear-claude' is mentioned",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "dear-claude": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "test": "bun test",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.25",
    "@googleapis/gmail": "^2.0.0",
    "@linear/sdk": "^29.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@octokit/rest": "^20.0.0",
    "commander": "^12.0.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "linear",
    "gmail",
    "github",
    "automation",
    "dear-claude"
  ],
  "author": "Shantanu",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
